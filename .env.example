# Servidor
NODE_ENV=development
PORT=3001

# Base de datos (Railway PostgreSQL)
# Runtime: usa el rol alma_app (DML only, least-privilege).
DATABASE_URL=
# Migraciones: usa el rol postgres (DDL + DML, solo para prisma migrate deploy).
# Si no se define, prisma migrate dev/deploy usan DATABASE_URL por defecto.
MIGRATION_DATABASE_URL=

# Autenticación
JWT_SECRET=
JWT_EXPIRES_IN=8h

# Seed (Fase 1)
SEED_SUPERADMIN_EMAIL=admin@nuvio.tech
SEED_SUPERADMIN_PASSWORD=

# Cifrado de client_intake (Fase 3a) — 32 bytes en base64.
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
INTAKE_ENCRYPTION_KEY=

# Cifrado de credenciales de WhatsApp (Fase 5) — 32 bytes en base64.
# Clave SEPARADA (compartimentación por radio de daño). Debe DIFERIR de INTAKE_ENCRYPTION_KEY.
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
WHATSAPP_TOKEN_ENCRYPTION_KEY=

# URL pública base para enlaces en notificaciones de reserva y recordatorios de WhatsApp.
# Usado en bookingNotifier.js y whatsappInboxService.js.
# Ejemplo: https://alma-spa-backend.up.railway.app
PUBLIC_BASE_URL=
