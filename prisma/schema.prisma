generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  superadmin
  dueno    @map("dueño")
  personal
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  config    Json     @default("{}")
  plan      String   @default("trial")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users                 User[]
  services              Service[]
  rooms                 Room[]
  plans                 Plan[]
  clients               Client[]
  clientIntakes         ClientIntake[]
  appointments          Appointment[]
  treatmentHistories    TreatmentHistory[]
  clientPlans           ClientPlan[]
  ledgerEntries         ClientLedgerEntry[]
  whatsappConnection    WhatsAppConnection?
  whatsappConversations WhatsAppConversation[]
  whatsappMessages      WhatsAppMessage[]
}

model User {
  id                    String   @id @default(cuid())
  tenantId              String?
  email                 String   @unique
  passwordHash          String
  name                  String
  role                  Role
  isProtected           Boolean  @default(false)
  active                Boolean  @default(true)
  canAttendAppointments Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  tenant               Tenant?             @relation(fields: [tenantId], references: [id])
  rolePermission       RolePermission?
  appointments         Appointment[]
  therapistSessions    TreatmentHistory[]  @relation("TherapistSessions")
  recordedTreatments   TreatmentHistory[]  @relation("RecordedTreatments")
  editedTreatments     TreatmentHistory[]  @relation("EditedTreatments")
  ledgerEntries        ClientLedgerEntry[] @relation("LedgerEntriesCreated")
  whatsappMessagesSent WhatsAppMessage[]   @relation("WhatsAppMessagesSent")

  @@index([tenantId, role, active, canAttendAppointments])
}

model RolePermission {
  id            String  @id @default(cuid())
  userId        String  @unique
  agenda        Boolean @default(false)
  gabinetes     Boolean @default(false)
  clientes      Boolean @default(false)
  crm           Boolean @default(false)
  reportes      Boolean @default(false)
  configuracion Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Service {
  id                String   @id @default(cuid())
  tenantId          String
  name              String
  category          String
  durationMins      Int      @default(60)
  priceUsd          Decimal  @db.Decimal(10, 2)
  offersHomeService Boolean  @default(false)
  active            Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  plans        Plan[]        @relation("PlanServices")
  appointments Appointment[]
  treatmentHistories TreatmentHistory[]

  @@index([tenantId, category, active])
}

enum RoomStatus {
  libre
  ocupado
  a_domicilio
}

model Room {
  id        String     @id @default(cuid())
  tenantId  String
  name      String
  specialty String
  status    RoomStatus @default(libre)
  active    Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  appointments Appointment[]

  @@index([tenantId, specialty, active])
}

model Plan {
  id                   String   @id @default(cuid())
  tenantId             String
  name                 String
  sessionsIncluded     Int
  period               String
  priceUsd             Decimal  @db.Decimal(10, 2)
  appliesToAllServices Boolean  @default(true)
  includesHomeService  Boolean  @default(false)
  active               Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  services    Service[]    @relation("PlanServices")
  clientPlans ClientPlan[]

  @@index([tenantId])
}

model Client {
  id        String   @id @default(cuid())
  tenantId  String
  fullName  String
  whatsapp  String
  email     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant                Tenant                 @relation(fields: [tenantId], references: [id])
  intake                ClientIntake?
  appointments          Appointment[]
  treatmentHistories    TreatmentHistory[]
  clientPlans           ClientPlan[]
  ledgerEntries         ClientLedgerEntry[]
  whatsappConversations WhatsAppConversation[]

  @@unique([tenantId, whatsapp])
  @@index([tenantId])
  @@index([tenantId, createdAt])
}

model ClientIntake {
  id              String    @id @default(cuid())
  tenantId        String
  clientId        String    @unique
  allergiesEnc    Bytes?
  allergiesIv     Bytes?
  allergiesTag    Bytes?
  conditionsEnc   Bytes?
  conditionsIv    Bytes?
  conditionsTag   Bytes?
  consentSigned   Boolean   @default(false)
  consentSignedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  client Client @relation(fields: [clientId], references: [id])

  @@index([tenantId])
}

enum AppointmentStatus {
  pendiente
  confirmado
  cancelado
  no_show
}

enum AppointmentModality {
  spa
  domicilio
}

model Appointment {
  id                String              @id @default(cuid())
  tenantId          String
  clientId          String
  serviceId         String
  modality          AppointmentModality @default(spa)
  roomId            String?
  homeAddress       String?
  staffId           String
  startsAt          DateTime
  endsAt            DateTime
  status            AppointmentStatus   @default(pendiente)
  confirmationToken String              @unique @default(cuid())
  priceUsd          Decimal             @db.Decimal(10, 2)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  client  Client  @relation(fields: [clientId], references: [id])
  service Service @relation(fields: [serviceId], references: [id])
  room    Room?   @relation(fields: [roomId], references: [id])
  staff   User    @relation(fields: [staffId], references: [id])
  treatmentHistory TreatmentHistory?

  @@index([tenantId])
  @@index([tenantId, startsAt])
  @@index([tenantId, status, startsAt])
  @@unique([roomId, startsAt])
  @@unique([staffId, startsAt])
}

model TreatmentHistory {
  id             String   @id @default(cuid())
  tenantId       String
  clientId       String
  serviceId      String
  therapistId    String
  createdById    String
  updatedById    String?
  appointmentId  String?  @unique
  sessionDate    DateTime
  notesEnc       Bytes?
  notesIv        Bytes?
  notesTag       Bytes?
  productsUsed   String[]
  photoBeforeUrl String?
  photoAfterUrl  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  client      Client       @relation(fields: [clientId], references: [id])
  service     Service      @relation(fields: [serviceId], references: [id])
  therapist   User         @relation("TherapistSessions", fields: [therapistId], references: [id])
  createdBy   User         @relation("RecordedTreatments", fields: [createdById], references: [id])
  updatedBy   User?        @relation("EditedTreatments", fields: [updatedById], references: [id])
  appointment Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  @@index([tenantId, clientId, sessionDate(sort: Desc)])
  @@index([tenantId, therapistId, sessionDate])
}

model ClientPlan {
  id               String   @id @default(cuid())
  tenantId         String
  clientId         String
  planId           String
  sessionsIncluded Int
  priceUsd         Decimal  @db.Decimal(10, 2)
  periodMonths     Int
  sessionsUsed     Int      @default(0)
  periodStart      DateTime @default(now())
  renewsAt         DateTime
  isComplimentary  Boolean  @default(false)
  active           Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  client Client @relation(fields: [clientId], references: [id])
  plan   Plan   @relation(fields: [planId], references: [id])

  @@index([tenantId, clientId, active])
}

enum LedgerEntryType {
  cargo
  pago
}

model ClientLedgerEntry {
  id                 String          @id @default(cuid())
  tenantId           String
  clientId           String
  type               LedgerEntryType
  amountUsd          Decimal         @db.Decimal(10, 2)
  description        String?
  method             String?
  createdById        String
  appointmentId      String?
  treatmentHistoryId String?
  clientPlanId       String?
  reversalOfId       String?         @unique
  createdAt          DateTime        @default(now())

  tenant    Tenant @relation(fields: [tenantId], references: [id])
  client    Client @relation(fields: [clientId], references: [id])
  createdBy User   @relation("LedgerEntriesCreated", fields: [createdById], references: [id])

  @@index([tenantId, clientId, createdAt])
  @@index([tenantId, type, createdAt])
}

enum IntakeAuditField {
  allergies
  conditions
  consent
}

enum IntakeAuditAction {
  read
  update
}

model ClientIntakeAuditLog {
  id        String            @id @default(cuid())
  tenantId  String
  clientId  String
  actorId   String
  field     IntakeAuditField
  action    IntakeAuditAction
  createdAt DateTime          @default(now())

  @@index([tenantId, clientId, createdAt])
  @@index([tenantId, actorId, createdAt])
}

// ---- Fase 5: CRM / WhatsApp Cloud API ---------------------------------------

enum WhatsAppConnStatus {
  activo
  desconectado
  error
}

enum WhatsAppDirection {
  inbound
  outbound
}

enum WhatsAppMessageType {
  text
  template
  image
  document
  audio
  video
  sticker
  location
  interactive
  other
}

enum WhatsAppMessageStatus {
  received
  queued
  sent
  delivered
  read
  failed
}

model WhatsAppConnection {
  id              String             @id @default(cuid())
  tenantId        String             @unique
  phoneNumberId   String             @unique
  wabaId          String
  displayPhone    String?
  accessTokenEnc  Bytes
  accessTokenIv   Bytes
  accessTokenTag  Bytes
  appSecretEnc    Bytes
  appSecretIv     Bytes
  appSecretTag    Bytes
  verifyTokenHash Bytes              @unique
  keyVersion      Int                @default(1)
  status          WhatsAppConnStatus @default(activo)
  lastError       String?
  lastVerifiedAt  DateTime?
  connectedAt     DateTime           @default(now())
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
}

model WhatsAppConversation {
  id                 String    @id @default(cuid())
  tenantId           String
  clientId           String?
  customerWaId       String
  customerName       String?
  lastInboundAt      DateTime?
  lastOutboundAt     DateTime?
  lastMessageAt      DateTime  @default(now())
  lastMessagePreview String?
  unreadCount        Int       @default(0)
  lastReadAt         DateTime?
  archived           Boolean   @default(false)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  tenant   Tenant            @relation(fields: [tenantId], references: [id])
  client   Client?           @relation(fields: [clientId], references: [id])
  messages WhatsAppMessage[]

  @@unique([tenantId, customerWaId])
  @@index([tenantId, lastMessageAt(sort: Desc)])
  @@index([tenantId, clientId])
}

model WhatsAppMessage {
  id             String                @id @default(cuid())
  tenantId       String
  conversationId String
  direction      WhatsAppDirection
  type           WhatsAppMessageType   @default(text)
  status         WhatsAppMessageStatus
  waMessageId    String?               @unique
  body           String?
  templateName   String?
  templateLang   String?
  mediaId        String?
  errorCode      String?
  errorTitle     String?
  sentByUserId   String?
  waTimestamp    DateTime?
  createdAt      DateTime              @default(now())

  tenant       Tenant               @relation(fields: [tenantId], references: [id])
  conversation WhatsAppConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sentBy       User?                @relation("WhatsAppMessagesSent", fields: [sentByUserId], references: [id])

  @@index([tenantId, conversationId, createdAt])
}
